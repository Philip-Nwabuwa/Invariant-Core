{
  "info": {
    "name": "Invariant Core",
    "description": "Manual-testing collection for Invariant Core. Health + Metrics cover the three service binaries (ledger :8081, switchd :8080, mockrail :8082). Transfers drives the public REST API on switchd (api/openapi/switch.yaml, v0.3.0): create a transfer with a required Idempotency-Key, poll until terminal (SETTLED / REVERSED / FAILED / MANUAL_REVIEW), and exercise idempotent replay, conflict, and validation. Service URLs are collection variables so the collection retargets (e.g. to a Railway domain) without editing requests. Run the Transfers folder top-to-bottom; the happy-path request seeds idempotency_key / transfer_id / transfer_reference for the requests after it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "ledger_url", "value": "http://localhost:8081", "type": "string" },
    { "key": "switchd_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "mockrail_url", "value": "http://localhost:8082", "type": "string" },
    { "key": "idempotency_key", "value": "", "type": "string" },
    { "key": "transfer_id", "value": "", "type": "string" },
    { "key": "transfer_reference", "value": "", "type": "string" }
  ],
  "item": [
