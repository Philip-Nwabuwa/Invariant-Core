# Copy to .env and adjust. The Makefile auto-includes .env.
# -----------------------------------------------------------------------------

# Database (matches docker-compose.yml credentials)
DB_URL=postgres://invariantcore:invariantcore@localhost:5432/invariantcore?sslmode=disable

# Redis (idempotency fast-path; cache only, Postgres is the record)
REDIS_ADDR=localhost:6379

# Tracing — OTLP gRPC into the all-in-one Jaeger from docker-compose.
# Leave empty to disable tracing (tracer becomes a no-op).
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
# ledger:   gRPC + health/metrics
LEDGER_GRPC_ADDR=:50051
LEDGER_HTTP_ADDR=:8081

# switchd:  public REST + health/metrics on one port; internal gRPC separate
SWITCHD_HTTP_ADDR=:8080
SWITCHD_GRPC_ADDR=:50052

# mockrail: primary listener + health/metrics
MOCKRAIL_ADDR=:50053
MOCKRAIL_HTTP_ADDR=:8082

# -----------------------------------------------------------------------------
# mockrail chaos knobs — deterministic by seed. Probabilities are 0.0–1.0.
# (Consumed starting Sprint 2/3; listed here so the contract is visible.)
# -----------------------------------------------------------------------------
MOCKRAIL_SEED=1
MOCKRAIL_LATENCY_MS=0
MOCKRAIL_P_TIMEOUT=0.0
MOCKRAIL_P_DUPLICATE=0.0
MOCKRAIL_P_DECLINE=0.0
